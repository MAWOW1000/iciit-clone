---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { normalizeAssetLinks } from '../../lib/routes.js';
import contentHtml from '../../content-fragments/iciit2018.html?raw';

const title = `ICIIT2026丨Intelligent Information Technology`;
const description = `About ICIIT 2018 2018 International Conference on Intelligent Information Technology (ICIIT 2018) has been held successfully in Vietnam Academy of Science`;
const content = normalizeAssetLinks(contentHtml);
---

<BaseLayout
  title={title}
  description={description}
  canonical={new URL('/iciit2018', Astro.site).toString()}
>
  <Fragment set:html={content} />
</BaseLayout>
