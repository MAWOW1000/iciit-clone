---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { normalizeAssetLinks } from '../../lib/routes.js';
import contentHtml from '../../content-fragments/iciit2020.html?raw';

const title = `ICIIT2026丨Intelligent Information Technology`;
const description = `About ICIIT 2020 2020 International Conference on Intelligent Information Technology (ICIIT 2020) has been held successfully in Hanoi, Vietnam during`;
const content = normalizeAssetLinks(contentHtml);
---

<BaseLayout
  title={title}
  description={description}
  canonical={new URL('/iciit2020', Astro.site).toString()}
>
  <Fragment set:html={content} />
</BaseLayout>
