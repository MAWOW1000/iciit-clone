---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { normalizeAssetLinks } from '../../lib/routes.js';
import contentHtml from '../../content-fragments/reg.html?raw';

const title = `ICIIT2026丨Intelligent Information Technology`;
const description = `Conference Registration Registration Fee for Regular Participants Categories Registration Fee (Regular) Registration Fee (Onsite Registration) Author`;
const content = normalizeAssetLinks(contentHtml);
---

<BaseLayout
  title={title}
  description={description}
  canonical={new URL('/reg/', Astro.site).toString()}
>
  <Fragment set:html={content} />
</BaseLayout>
