---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { normalizeAssetLinks } from '../../lib/routes.js';
import contentHtml from '../../content-fragments/iciit2025.html?raw';

const title = `ICIIT2026丨Intelligent Information Technology`;
const description = `About ICIIT 202 5 202 5 International Conference on Intelligent Information Technology (ICIIT 202 5 ) has been held successfully in Hanoi, Vietnam`;
const content = normalizeAssetLinks(contentHtml);
---

<BaseLayout
  title={title}
  description={description}
  canonical={new URL('/iciit2025', Astro.site).toString()}
>
  <Fragment set:html={content} />
</BaseLayout>
