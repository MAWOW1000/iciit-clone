---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { normalizeAssetLinks } from '../../lib/routes.js';
import contentHtml from '../../content-fragments/com.html?raw';

const title = `ICIIT2026丨Intelligent Information Technology`;
const description = `Conference Organizing Committee General Chairs Dr. Le Minh Duc, Head of Information Technology, Swinburne Vietnam, Hanoi Camupus, Vietnam Prof. Edmund Lai,`;
const content = normalizeAssetLinks(contentHtml);
---

<BaseLayout
  title={title}
  description={description}
  canonical={new URL('/com', Astro.site).toString()}
>
  <Fragment set:html={content} />
</BaseLayout>
