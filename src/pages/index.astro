---
import BaseLayout from '../layouts/BaseLayout.astro';
import { normalizeAssetLinks } from '../lib/routes.js';
import contentHtml from '../content-fragments/index.html?raw';

const title = `ICIIT2026丨Intelligent Information Technology`;
const description = `Welcome to ICIIT 2026! Call for Papers of Intelligent Information Technology March 05-08, 2026, Da Nang, Vietnam Welcome to ICIIT 2026! ( Brochure Download )`;
const content = normalizeAssetLinks(contentHtml);
---

<BaseLayout title={title} description={description} canonical={new URL('/', Astro.site).toString()}>
  <Fragment set:html={content} />
</BaseLayout>
