---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { normalizeAssetLinks } from '../../lib/routes.js';
import contentHtml from '../../content-fragments/invited.html?raw';

const title = `ICIIT2026丨Intelligent Information Technology`;
const description = `Invited Speakers 2026 11th International Conference on Intelligent Information Technology (ICIIT) aims to gather professors, researchers, scholars and`;
const content = normalizeAssetLinks(contentHtml);
---

<BaseLayout
  title={title}
  description={description}
  canonical={new URL('/invited/', Astro.site).toString()}
>
  <Fragment set:html={content} />
</BaseLayout>
