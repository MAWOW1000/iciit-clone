---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { normalizeAssetLinks } from '../../lib/routes.js';
import contentHtml from '../../content-fragments/iciit2021.html?raw';

const title = `ICIIT2026丨Intelligent Information Technology`;
const description = `About ICIIT 2021 2021 International Conference on Intelligent Information Technology (ICIIT 2021) has been held successfully in Ho Chi Minh, Vietnam (Online)`;
const content = normalizeAssetLinks(contentHtml);
---

<BaseLayout
  title={title}
  description={description}
  canonical={new URL('/iciit2021', Astro.site).toString()}
>
  <Fragment set:html={content} />
</BaseLayout>
