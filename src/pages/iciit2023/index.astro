---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { normalizeAssetLinks } from '../../lib/routes.js';
import contentHtml from '../../content-fragments/iciit2023.html?raw';

const title = `ICIIT2026丨Intelligent Information Technology`;
const description = `About ICIIT 2023 2023 International Conference on Intelligent Information Technology (ICIIT 2023) has been held successfully in Da Nang, Vietnam`;
const content = normalizeAssetLinks(contentHtml);
---

<BaseLayout
  title={title}
  description={description}
  canonical={new URL('/iciit2023', Astro.site).toString()}
>
  <Fragment set:html={content} />
</BaseLayout>
